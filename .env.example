# Eldoria website API — copy to .env and fill in values
API_PORT=3001
APP_URL=https://eldoriarealm.com

# Shockbyte — IP used by the API to query mcstatus + bridge (keep as numeric host)
MC_HOST=103.15.237.56
MC_PORT=23383
# Domain players type in Minecraft (shown on the website)
MC_JOIN_HOST=eldoriarealm.com

# Session secret (generate a random string)
SESSION_SECRET=change-this-to-a-long-random-string

# Discord OAuth — https://discord.com/developers/applications
# Redirect URI must match exactly: http://localhost:5173/api/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5173/api/auth/discord/callback

# Chief (owner) — auto-assigned on signup
CHIEF_MINECRAFT_USERNAMES=cmancnt
# DISCORD_CHIEF_IDS=your-discord-user-id

# Staff roles by Minecraft username (username:role, comma-separated)
STAFF_MINECRAFT_ROLES=nelscnt:moderator,glumlow:moderator

# Eldoria Bridge mod on Shockbyte
BRIDGE_URL=http://103.15.237.56:26871
BRIDGE_API_KEY=your-secret-key-from-eldoria-bridge.json
